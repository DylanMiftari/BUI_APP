<IfModule mod_rewrite.c>
  RewriteEngine On

  # Si le fichier ou le dossier demandé existe physiquement (ex: images, styles), le servir directement
  RewriteCond %{REQUEST_FILENAME} -s [OR]
  RewriteCond %{REQUEST_FILENAME} -l [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^.*$ - [NC,L]

  # Sinon, rediriger toutes les autres requêtes vers index.html
  RewriteRule ^(.*) index.html [NC,L]
</IfModule>